// ===================
// GENERATOR & DATASOURCE
// ===================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================
// ENUMS
// ===================
enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementTargetType {
  SCHOOL
  CLASS
  COURSE
  USER
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

// ===================
// USER
// ===================
model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  studentRequests ClassAssignmentRequest[] @relation("StudentRequests")
  teacherRequests ClassAssignmentRequest[] @relation("TeacherRequests")

  courses        Course[]        @relation("TeacherCourses")
  quizAttempts   QuizAttempt[]
  announcements  Announcement[]  @relation("UserAnnouncements")
  aiInteractions AIInteraction[]

  createdAt   DateTime      @default(now())
  ClassMember ClassMember[]
  Quiz        Quiz[]
}

// ===================
// CLASS
// ===================
model Class {
  id    String @id @default(uuid())
  name  String
  level String
  group String

  students      User[]
  members       ClassMember[]
  courses       Course[]
  classRequests ClassAssignmentRequest[]

  announcements Announcement[]

  createdAt         DateTime            @default(now())
  AnnouncementClass AnnouncementClass[]
  QuizClass         QuizClass[]

  @@unique([level, group])
}

// ===================
// CLASS ASSIGNMENTS
// ===================
model ClassAssignmentRequest {
  id        String        @id @default(uuid())
  studentId String
  classId   String
  teacherId String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())

  student User  @relation("StudentRequests", fields: [studentId], references: [id])
  teacher User  @relation("TeacherRequests", fields: [teacherId], references: [id])
  class   Class @relation(fields: [classId], references: [id])
}

model ClassMember {
  id      String @id @default(uuid())
  userId  String
  classId String

  user  User  @relation(fields: [userId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  @@unique([userId, classId])
}

// ===================
// COURSES & LESSONS
// ===================
model Course {
  id          String @id @default(uuid())
  title       String
  description String
  classId     String
  teacherId   String

  class   Class @relation(fields: [classId], references: [id])
  teacher User  @relation("TeacherCourses", fields: [teacherId], references: [id])

  lessons       Lesson[]
  announcements Announcement[]

  createdAt DateTime @default(now())
}

model Lesson {
  id       String  @id @default(uuid())
  title    String
  content  String
  videoUrl String?
  courseId String

  course         Course          @relation(fields: [courseId], references: [id])
  quiz           Quiz?           @relation(fields: [quizId], references: [id])
  aiContext      String? // AI chat or video tutor
  aiInteractions AIInteraction[]

  createdAt DateTime @default(now())
  quizId    String?
}

model Quiz {
  id          String   @id @default(uuid())
  title       String
  description String?
  teacherId   String
  createdAt   DateTime @default(now())

  teacher   User        @relation(fields: [teacherId], references: [id])
  classes   QuizClass[] // relation to assigned classes
  questions Question[]

  attempts QuizAttempt[]
  Lesson   Lesson[]
}

model QuizClass {
  id      String @id @default(uuid())
  quizId  String
  classId String

  quiz  Quiz  @relation(fields: [quizId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  @@unique([quizId, classId])
}

model Question {
  id       String       @id @default(uuid())
  quizId   String
  type     QuestionType
  question String
  options  Json?
  answer   String

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id      String @id @default(uuid())
  userId  String
  quizId  String
  score   Int
  answers Json

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, quizId])
}

// ===================
// AI INTERACTIONS
// ===================
model AIInteraction {
  id       String  @id @default(uuid())
  userId   String
  lessonId String?
  type     String // CHAT or VIDEO
  messages Json

  user   User    @relation(fields: [userId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
}

model Announcement {
  id         String                 @id @default(uuid())
  title      String
  content    String
  targetType AnnouncementTargetType

  classId  String?
  courseId String?
  userId   String?

  class  Class?  @relation(fields: [classId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
  user   User?   @relation("UserAnnouncements", fields: [userId], references: [id])

  createdAt         DateTime            @default(now())
  AnnouncementClass AnnouncementClass[]
}

model AnnouncementClass {
  id             String @id @default(uuid())
  announcementId String
  classId        String

  announcement Announcement @relation(fields: [announcementId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])

  @@unique([announcementId, classId])
}
