// ===================
// GENERATOR & DATASOURCE
// ===================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================
// ENUMS
// ===================
enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum ContentType {
  LESSON
  TOPIC
  SUBTOPIC
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum AnnouncementTargetType {
  SCHOOL
  CLASS
  COURSE
  USER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  TEXT
}
// ===================
// CORE MODELS
// ===================

model School {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String?
  createdAt DateTime @default(now())

  users         User[]
  classes       Class[]
  courses       Course[]
  announcements Announcement[]
}

model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  password String
  role     Role
  status   UserStatus @default(ACTIVE)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  assignedClassId String?
  assignedClass   Class?  @relation("AssignedUsers", fields: [assignedClassId], references: [id])
  studentClassId  String?
  studentClass    Class?  @relation("StudentClass", fields: [studentClassId], references: [id])
  teacherClassId  String?
  teacherClass    Class?  @relation("TeacherClass", fields: [teacherClassId], references: [id])
  mainClassId     String? @unique
  mainClass       Class?  @relation("MainTeacher", fields: [mainClassId], references: [id])

  studentRequests  ClassAssignmentRequest[] @relation("StudentRequests")
  teacherRequests  ClassAssignmentRequest[] @relation("TeacherRequests")

  courses        Course[] @relation("TeacherCourses")
  createdCourses Course[] @relation("CreatedCourses")

  assignments         assignment[]
  assignmentAttempts  assignmentAttempt[]

  announcements    Announcement[] @relation("UserAnnouncements")
  aiInteractions   AIInteraction[]
  classMemberships ClassMember[]
  liveSessions LiveSession[]

  attendanceAsStudent Attendance[] @relation("StudentAttendance")
  attendanceAsTeacher Attendance[] @relation("TeacherAttendance")
  receivedNotifications Notification[] @relation("ReceivedNotifications")
  

  createdAt DateTime @default(now())
}

model Class {
  id    String @id @default(uuid())
  name  String
  level String
  group String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  assignedUsers User[] @relation("AssignedUsers")
  students      User[] @relation("StudentClass")
  teachers      User[] @relation("TeacherClass")
  mainTeacher   User?  @relation("MainTeacher")

  memberships         ClassMember[]
  courses             Course[]
  classRequests       ClassAssignmentRequest[]
  announcements       Announcement[]
  assignmentClasses   assignmentClass[]
  attendance          Attendance[]
  announcementClasses AnnouncementClass[]
  liveSessions LiveSession[]
  createdAt DateTime @default(now())

  @@unique([schoolId, level, group])
}

// ===================
// COURSE & CONTENT
// ===================

model Course {
  id          String @id @default(uuid())
  title       String
  description String @db.Text

  classId     String
  teacherId   String
  schoolId    String
  createdById String

  class     Class  @relation(fields: [classId], references: [id])
  teacher   User   @relation("TeacherCourses", fields: [teacherId], references: [id])
  school    School @relation(fields: [schoolId], references: [id])
  createdBy User   @relation("CreatedCourses", fields: [createdById], references: [id])

  contents      CourseContent[]
  announcements Announcement[]
  assignments   assignment[]

  createdAt DateTime @default(now())
}

model CourseContent {
  id    String      @id @default(uuid())
  title String
  type  ContentType

  notes        String?  @db.Text
  videoUrl     String?
  materialUrl  String?
  reviewPoints String[]

  parentId String?
  parent   CourseContent?  @relation("ContentHierarchy", fields: [parentId], references: [id])
  children CourseContent[] @relation("ContentHierarchy")

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  assignments    assignment[]
  aiInteractions AIInteraction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================
// ASSIGNMENTS
// ===================

model assignment {
  id              String   @id @default(uuid())
  title           String
  instruction     String?  @db.Text
  duration        Int      @default(30)
  passMark        Int      @default(50)
  negativeMarking Float    @default(0)

  teacherId String
  teacher   User @relation(fields: [teacherId], references: [id])

  contentId String?
  content   CourseContent? @relation(fields: [contentId], references: [id])

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id])

  assignmentClasses  assignmentClass[]
  questions          Question[]
  assignmentAttempts assignmentAttempt[]

  createdAt DateTime @default(now())
}

model Question {
  id           String       @id @default(uuid())
  assignmentId String
  assignment   assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  prompt  String @db.Text
  type    QuestionType
  weight  Int    @default(5)

  options Json?     // ✅ This works for MCQ options
  answer  String?   // ✅ Will store correct answer (MCQ, TRUE_FALSE, TEXT)

  submissionAnswers SubmissionAnswer[]
}

// ===================
// ASSIGNMENT ATTEMPTS
// ===================

model assignmentAttempt {
  id           String   @id @default(uuid())
  userId       String
  assignmentId String

  user       User       @relation(fields: [userId], references: [id])
  assignment assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  score     Float
  passed    Boolean @default(false)
  graded    Boolean @default(false)

  answers Json  // ✅ This can store student answers as JSON array

  submissionAnswers SubmissionAnswer[]

  createdAt DateTime @default(now())

  @@unique([userId, assignmentId])
}

model SubmissionAnswer {
  id        String @id @default(uuid())

  attemptId  String
  questionId String

  selectedAnswer String?  // ✅ student choice
  correctAnswer  String?  // ✅ correct choice
  isCorrect      Boolean  // ✅ mark true/false

 
  attempt  assignmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id], onDelete: Cascade) 
}

// ===================
// SUPPORT MODELS
// ===================

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  teacherId String
  classId   String
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime @default(now())

  student User  @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("TeacherAttendance", fields: [teacherId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date], name: "student_class_date")
}

model AIInteraction {
  id        String @id @default(uuid())
  userId    String
  type      String
  messages  Json

  contentId String?
  content   CourseContent? @relation(fields: [contentId], references: [id])

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ClassAssignmentRequest {
  id        String @id @default(uuid())
  studentId String
  teacherId String
  classId   String
  status    RequestStatus @default(PENDING)

  createdAt DateTime @default(now())

  student User  @relation("StudentRequests", fields: [studentId], references: [id])
  teacher User  @relation("TeacherRequests", fields: [teacherId], references: [id])
  class   Class @relation(fields: [classId], references: [id])
}

model ClassMember {
  id      String @id @default(uuid())
  userId  String
  classId String

  user  User  @relation(fields: [userId], references: [id])
  class Class @relation(fields: [classId], references: [id])

  @@unique([userId, classId])
}

model assignmentClass {
  id           String @id @default(uuid())
  assignmentId String
  classId      String

  assignment assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  class      Class      @relation(fields: [classId], references: [id])

  @@unique([assignmentId, classId])
}

// ===================
// ANNOUNCEMENTS
// ===================

model Announcement {
  id         String                 @id @default(uuid())
  title      String
  content    String                 @db.Text
  targetType AnnouncementTargetType

  schoolId String?
  classId  String?
  courseId String?
  userId   String?

  school School? @relation(fields: [schoolId], references: [id])
  class  Class?  @relation(fields: [classId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
  user   User?   @relation("UserAnnouncements", fields: [userId], references: [id])

  announcementClasses AnnouncementClass[]

  createdAt DateTime @default(now())
}

model AnnouncementClass {
  id             String @id @default(uuid())
  announcementId String
  classId        String

  announcement Announcement @relation(fields: [announcementId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])

  @@unique([announcementId, classId])
}



model Notification {
  id          String   @id @default(uuid())
  recipientId String   // The user who receives the notification
  senderId    String?  // The user who triggered the action
  type        String   // 'NEW_TEST', 'MARKS_RELEASED', 'ATTENDANCE', 'NEW_COURSE'
  title       String
  message     String
  link        String?  // Optional: URL to redirect the user (e.g., /courses/123)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id])
}


model LiveSession {
  id           String        @id @default(uuid())
  title        String
  status       SessionStatus @default(SCHEDULED)
  
  // Relations
  classId      String        // The specific group/section
  class        Class         @relation(fields: [classId], references: [id])
  
  teacherId    String
  teacher      User          @relation(fields: [teacherId], references: [id])
  
  // Timing & Data
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  recordingUrl String?
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([classId])
  @@index([status])
}

